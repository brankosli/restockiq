{
  "name": "restockiq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx --env-file=.env.local --tsconfig tsconfig.worker.json src/worker/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.0.0",
    "@neondatabase/serverless": "^0.10.0",
    "@shopify/shopify-api": "^11.0.0",
    "@shopify/shopify-app-session-storage-drizzle": "^1.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "axios": "^1.7.0",
    "bullmq": "^5.0.0",
    "clsx": "^2.1.0",
    "csv-writer": "^1.6.0",
    "date-fns": "^4.0.0",
    "drizzle-orm": "^0.38.4",
    "exceljs": "^4.4.0",
    "ioredis": "^5.4.0",
    "next": "^15.0.0",
    "nodemailer": "^6.9.0",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^17.0.0",
    "tailwind-merge": "^2.5.0",
    "twilio": "^5.13.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.29.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
